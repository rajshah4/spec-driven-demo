{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenSpec Feature Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "feature",
    "issue",
    "problem_statement",
    "user_stories",
    "requirements",
    "acceptance_criteria",
    "out_of_scope",
    "open_questions"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "feature": {
      "type": "string",
      "minLength": 1
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "title", "url"],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "problem_statement": {
      "type": "string",
      "minLength": 1
    },
    "user_stories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["as_a", "i_want", "so_that"],
        "properties": {
          "as_a": {
            "type": "string",
            "minLength": 1
          },
          "i_want": {
            "type": "string",
            "minLength": 1
          },
          "so_that": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["must_have", "should_have", "nice_to_have"],
      "properties": {
        "must_have": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "should_have": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "nice_to_have": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
